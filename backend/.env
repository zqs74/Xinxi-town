# MongoDB 连接字符串
# 本地开发使用：
MONGODB_URI=mongodb://localhost:27017/xinxi-town
# 如果使用MongoDB Atlas云数据库，格式如下：
# MONGODB_URI=mongodb+srv://用户名:密码@集群地址/数据库名?retryWrites=true&w=majority

# JWT 密钥（重要：生产环境要使用复杂的随机字符串）
JWT_SECRET=xinxi-town-secret-key-change-this-in-production

# 服务器端口
PORT=5000

# CORS 配置（前端地址）
CORS_ORIGIN=http://localhost:5173

# 百度AI API配置（如果需要真实情感分析）
BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_SECRET_KEY=your_baidu_secret_key_here

# 其他AI服务配置
AI_SERVICE_ENABLED=true

# 邮件服务配置（如果需要发送验证邮件）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# 调试模式
NODE_ENV=development
DEBUG=true

# backend/.env 文件中添加：
